library(stringr)

action_words <- c(
  "must",
  "need to",
  "take action",
  "act now",
  "cannot allow",
  "complicit",
  "demand",
  "debate",
  "reform",
  "ban"
)

alltweets_with_party_filled <- alltweets_with_party_filled %>%
  mutate(action_language = str_detect(
    tolower(text),
    paste(action_words, collapse = "|")
  ))
action_summary <- alltweets_with_party_filled %>%
  filter(party_clean %in% c("Democrat", "Republican")) %>%
  group_by(party_clean) %>%
  summarise(
    action_rate = mean(action_language, na.rm = TRUE),
    n = n()
  )

action_summary
prop.test(
  table(
    alltweets_with_party_filled$party_clean,
    alltweets_with_party_filled$action_language
  )
)

