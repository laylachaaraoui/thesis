library(ggplot2)
library(dplyr)

datasets <- list(
  "Parkland" = parkland_filtered2,
  "Aurora" = aurora_filtered2,
  "Orlando" = orlando_filtered2,
  "Sandy Hook" = sandyhook_filtered,
  "Vegas" = vegas_filtered2
)
colors <- c(
  "Parkland" = "#1f77b4",
  "Aurora" = "#ff7f0e",
  "Orlando" = "#2ca02c",
  "Sandy Hook" = "#d62728",
  "Vegas" = "#9467bd"
)
plot_sentiment <- function(df, title) {
  df <- df %>%
    mutate(sentiment_bin = cut(
      sentiment,
      breaks = seq(-1, 1, by = 0.05),
      include.lowest = TRUE,
      labels = seq(-0.975, 0.975, by = 0.05)
    )) %>%
    mutate(sentiment_bin = as.numeric(as.character(sentiment_bin)))
  
  df_summary <- df %>%
    group_by(sentiment_bin) %>%
    summarise(count = n(), .groups = "drop") %>%
    mutate(prop = count / sum(count))
  
  ggplot(df_summary, aes(x = sentiment_bin, y = prop)) +
    geom_col(fill = colors[title]) +
    scale_y_continuous(labels = scales::percent) +
    scale_x_continuous(breaks = c(-1, 0, 1), limits = c(-1, 1)) +
    labs(
      title = paste("Sentiment Distribution —", title, "Tweets"),
      x = "Sentiment Score",
      y = "Proportion of Tweets"
    ) +
    theme_minimal()
}
plots <- lapply(names(datasets), function(name) {
  plot_sentiment(datasets[[name]], name)
})
plots[[1]]  # Parkland in blue
plots[[2]]  # Aurora in orange
plots[[3]]  # Orlando in green
plots[[4]]  # Sandy Hook in red
plots[[5]]  # Vegas in purple

