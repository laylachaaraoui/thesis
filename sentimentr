install.packages("sentimentr")
library(sentimentr)
library(dplyr)
library(sentimentr)

parkland_sentences <- get_sentences(parkland_filtered2$text)
parkland_sentiment <- sentiment_by(parkland_sentences)
parkland_filtered2$sentiment <- parkland_sentiment$ave_sentiment
summary(parkland_filtered2$sentiment)
View(parkland_filtered2)

vegas_sentences <- get_sentences(vegas_filtered2$text)
