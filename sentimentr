library(dplyr)
ci95 <- function(x) {
  n <- sum(!is.na(x))
  mean_x <- mean(x, na.rm = TRUE)
  se <- sd(x, na.rm = TRUE) / sqrt(n)
  lower <- mean_x - 1.96 * se
  upper <- mean_x + 1.96 * se
  return(c(lower = lower, upper = upper))
}
sentiment_ci_summary <- alltweets_sentiment %>%
  group_by(case_study) %>%
  summarize(
    mean_sentiment = mean(ave_sentiment, na.rm = TRUE),
    ci_lower = ci95(ave_sentiment)[1],
    ci_upper = ci95(ave_sentiment)[2],
    n_tweets = n()
  )
print(sentiment_ci_summary)

