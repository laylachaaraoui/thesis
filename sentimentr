sandyhook_filtered$sentiment <- sandyhook_sentiment$ave_sentiment

orlando_sentences <- get_sentences(orlando_filtered2$text)
orlando_sentiment <- sentiment_by(orlando_sentences)
orlando_filtered2$sentiment <- orlando_sentiment$ave_sentiment

library(ggplot2)

ggplot(parkland_filtered2, aes(x = sentiment)) +
  geom_histogram(binwidth = 0.1, fill = "steelblue", color = "black", alpha = 0.7) +
  labs(
    title = "Sentiment Distribution — Parkland Tweets",
    x = "Sentiment Score (Negative → Positive)",
    y = "Number of Tweets"
  ) +
  theme_minimal()

