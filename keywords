mental_pattern <- paste0("\\b(", paste(mental_health_words, collapse = "|"), ")\\b")
gun_pattern <- paste0("\\b(", paste(gun_words, collapse = "|"), ")\\b")
sympathy_pattern <- paste0("\\b(", paste(sympathy_words, collapse = "|"), ")\\b")

alltweets_with_party_filled <- alltweets_with_party_filled %>%
  mutate(
    gun_topic = str_detect(tolower(text), gun_pattern),
    mental_topic = str_detect(tolower(text), mental_pattern),
    sympathy_topic = str_detect(tolower(text), sympathy_pattern)
  )

topic_rates <- alltweets_with_party_filled %>%
  filter(party_clean %in% c("Democrat", "Republican")) %>%
  group_by(year, party_clean) %>%
  summarise(
    total_tweets = n(),
    gun_mentions = sum(gun_topic, na.rm = TRUE),
    mental_mentions = sum(mental_topic, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    gun_rate = gun_mentions / total_tweets,
    mental_rate = mental_mentions / total_tweets
  ) %>%
  pivot_longer(
    cols = c(gun_rate, mental_rate),
    names_to = "topic",
    values_to = "rate"
  ) %>%
  mutate(
    topic = recode(topic,
                   gun_rate = "Gun References",
                   mental_rate = "Mental Health References")
  )

ggplot(topic_rates,
       aes(x = year, y = rate, color = party_clean, group = party_clean)) +
  geom_line(linewidth = 1.3) +
  geom_point(size = 3) +
  facet_wrap(~topic, scales = "free_y") +
  scale_color_manual(values = c(
    "Democrat" = "#a6cee3",
    "Republican" = "#fb9a99"
  )) +
  scale_y_continuous(labels = scales::percent_format()) +
  labs(
    title = "Proportion of Tweets Referencing Guns vs Mental Health Over Time",
    x = "Year",
    y = "Share of Tweets",
    color = "Party"
  ) +
  theme_minimal(base_size = 14)

