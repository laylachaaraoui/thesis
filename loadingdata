library(jsonlite)
library(dplyr)
library(readr)
tweets_file <- "/Users/laylachaaraoui/Downloads/archive-2/tweets.json"
start_epoch <- 1355443200
end_epoch   <- 1358121600
sandy_hook <- data.frame()
con <- file(tweets_file, "r")
chunk_size <- 10000
repeat {
  lines <- readLines(con, n = chunk_size)
  if (length(lines) == 0) break
  chunk <- stream_in(
    textConnection(lines),
    verbose = FALSE,
    flatten = TRUE
  )
  if ("created_at" %in% names(chunk)) {
    chunk$created_at <- as.numeric(chunk$created_at)
    chunk_filtered <- chunk %>%
      filter(created_at >= start_epoch &
             created_at <= end_epoch)
    chunk_filtered <- chunk_filtered %>%
      mutate(across(everything(), as.character))
    sandy_hook <- bind_rows(sandy_hook, chunk_filtered)
    cat("Tweets collected so far:", nrow(sandy_hook), "\n")
  }
}
close(con)
cat("Final Sandy Hook tweet count:", nrow(sandy_hook), "\n")
write_csv(sandy_hook, "sandy_hook_tweets.csv")
cat("Saved to sandy_hook_tweets.csv\n")
