titles <- c("Governor", "Senator", "U.S.", "Rep.", "Representative", "Sen.", "Congressman", "Congresswoman")

users_split <- users_flat %>%
  mutate(
    name_clean = str_remove_all(name, paste(titles, collapse = "|")),
    name_clean = str_squish(name_clean),
    name_words = str_split(name_clean, " "),
    first_name = map_chr(name_words, ~ .x[1]),
    last_name  = map_chr(name_words, ~ tail(.x, 1)),
    first_name_lower = str_to_lower(first_name),
    last_name_lower  = str_to_lower(last_name)
  ) %>%
  select(screen_name, first_name, last_name, first_name_lower, last_name_lower)
legislators_match <- legislators %>%
  mutate(
    first_name_lower = str_to_lower(first_name),
    last_name_lower  = str_to_lower(last_name)
  ) %>%
  select(first_name_lower, last_name_lower, full_name, party)
users_with_party <- users_split %>%
  left_join(legislators_match, by = c("first_name_lower", "last_name_lower"))
legislators_last <- legislators_match %>%
  select(last_name_lower, full_name_last = full_name, party_last = party) %>%
  distinct()
users_with_party <- users_with_party %>%
  left_join(legislators_last, by = "last_name_lower") %>%
  mutate(
    full_name = if_else(is.na(full_name), full_name_last, full_name),
    party     = if_else(is.na(party), party_last, party)
  ) %>%
  select(screen_name, full_name, party) %>%
  distinct(screen_name, .keep_all = TRUE) 
alltweets_with_party <- alltweets %>%
  left_join(users_with_party, by = "screen_name")
