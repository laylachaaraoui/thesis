fuzzy_fill_party <- function(screen_name, users_df) {
  distances <- stringdist::stringdist(screen_name, users_df$screen_name, method = "lv")
  min_idx <- which.min(distances)
  if(distances[min_idx] <= 3) {
    return(users_df$party[min_idx])
  } else {
    return(NA_character_)
  }
}

alltweets_with_party <- alltweets_with_party %>%
  rowwise() %>%
  mutate(
    party = if_else(
      is.na(party),
      fuzzy_fill_party(screen_name, users_with_party),
      party
    )
  ) %>%
  ungroup()
