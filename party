library(dplyr)
library(stringdist)
na_tweets <- alltweets_with_party %>% filter(is.na(party))
fuzzy_fill_party <- function(screen_name, users_df) {
  distances <- stringdist::stringdist(screen_name, users_df$screen_name, method = "lv")
  min_idx <- which.min(distances)
  if(distances[min_idx] <= 3) {
    return(users_df$party[min_idx])
  } else {
    return(NA_character_)
  }
}

alltweets_with_party <- alltweets_with_party %>%
  rowwise() %>%
  mutate(
    party = if_else(
      is.na(party),
      fuzzy_fill_party(screen_name, users_with_party),
      party
    )
  ) %>%
  ungroup()
na_rows <- alltweets_export %>% filter(is.na(party))
legislators_flat <- legislators %>%
  mutate(full_name_lower = str_to_lower(full_name)) %>%
  select(full_name, full_name_lower, party)

na_rows <- na_rows %>%
  rowwise() %>%
  mutate(
    matched_full_name = {
      user_name_lower <- str_to_lower(name)
      matches <- legislators_flat$full_name[legislators_flat$full_name_lower %in% user_name_lower | str_detect(user_name_lower, legislators_flat$full_name_lower)]
      if(length(matches) > 0) matches[1] else NA_character_
    },
    matched_party = {
      if(!is.na(matched_full_name)){
        legislators_flat$party[legislators_flat$full_name == matched_full_name]
      } else NA_character_
    }
  ) %>%
  ungroup()

alltweets_export <- alltweets_export %>%
  left_join(
    na_rows %>% select(screen_name, matched_full_name, matched_party),
    by = "screen_name"
  ) %>%
  mutate(
    full_name = if_else(is.na(full_name), matched_full_name, full_name),
    party     = if_else(is.na(party), matched_party, party)
  ) %>%
  select(-matched_full_name, -matched_party)
