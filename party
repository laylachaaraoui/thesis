library(dplyr)

# Combine all case study datasets into one
alltweets <- bind_rows(
  orlando_filtered,
  parkland_filtered,
  sandyhook_filtered,
  vegas_filtered,
  aurora_filtered
)

# Quick check
dim(alltweets)
head(alltweets)
